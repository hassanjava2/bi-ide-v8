# BI-IDE v8 - VPS Environment Configuration
# Place this file at /opt/bi-ide/.env on the VPS (Hostinger)

# ─── Training Data Relay ───────────────────────────────────────
# Relay training samples to RTX 5090 for GPU training
# Use Tailscale IP if VPS can't see LAN (192.168.1.164)
TRAINING_RELAY_ENABLED=true
TRAINING_RELAY_UPSTREAM_URL=http://192.168.1.164:8090
# Alternative: use Tailscale IP: http://100.x.x.x:8090
TRAINING_RELAY_TIMEOUT_SEC=15
TRAINING_NODE_NAME=hostinger-vps

# ─── API Settings ──────────────────────────────────────────────
LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
